# AutoForge Environment Configuration
# Copy this file to .env and fill in your values

# ─── GitLab Configuration ───
GITLAB_URL=https://gitlab.com
GITLAB_API_TOKEN=your_gitlab_personal_access_token
GITLAB_WEBHOOK_SECRET=your_webhook_secret_token
GITLAB_DEFAULT_PROJECT_ID=

# ─── Anthropic (Claude) Configuration ───
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# ─── Database Configuration ───
DATABASE_URL=postgresql://autoforge:autoforge@localhost:5432/autoforge
REDIS_URL=redis://localhost:6379/0

# ─── Vector Database ───
CHROMA_HOST=localhost
CHROMA_PORT=8100
CHROMA_COLLECTION=autoforge_memory

# ─── Application Settings ───
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
APP_HOST=0.0.0.0
SECRET_KEY=your_secret_key_change_in_production
LOG_LEVEL=INFO

# ─── Agent Configuration ───
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT_SECONDS=120
AGENT_CONFIDENCE_THRESHOLD=0.7
AGENT_RISK_THRESHOLD=0.8

# ─── Celery / Task Queue ───
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Dashboard ───
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─── GreenOps Configuration ───
GREENOPS_CARBON_FACTOR=0.000475  # kg CO2 per kWh (global average)
GREENOPS_CPU_POWER_DRAW=65       # watts per CPU core
GREENOPS_MEMORY_POWER_DRAW=0.3   # watts per GB RAM
